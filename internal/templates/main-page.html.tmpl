<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="public/gini-logo.png">

    <title>Gini | Scaffold Go Projects Fast</title>
    <meta name="description" content="Gini — Open-source CLI tool to scaffold Go projects quickly with sensible defaults and minimal friction.">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="public/css/style.css">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://gini.rafael.dev/">
    <meta property="og:title" content="Gini — Go Init | Fast Go Scaffolding">
    <meta property="og:description" content="Scaffold Go projects in seconds with Gini. Designed for speed and consistency.">
    <meta property="og:image" content="public/Gini.png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content="Gini — Go Init | Fast Go Scaffolding">
    <meta property="twitter:description" content="Scaffold Go projects in seconds with Gini. Designed for speed and consistency.">
    <meta property="twitter:image" content="public/Gini.png">
</head>

<body>
    <div class="container">
        <header>
            <div class="logo-glow" aria-hidden="true">
                <img src="public/gini-logo.png" alt="Gini logo" />
            </div>
            <h1>Gini — Go Init</h1>
            <p class="tagline">Scaffold production-ready Go projects in seconds. Skip the boilerplate, focus on your logic.</p>
        </header>

        <section class="terminal-window">
            <div class="terminal-header">
                <div class="dot dot-red"></div>
                <div class="dot dot-yellow"></div>
                <div class="dot dot-green"></div>
            </div>
            <div class="terminal-body">
                <div id="terminal-content"></div>
            </div>
        </section>

        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon"></div>
                <h3>Instant Scaffolding</h3>
                <p>Generate a clean, standard-compliant project layout in seconds. No more manual folder creation.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"></div>
                <h3>Zero Friction</h3>
                <p>Sensible defaults and essential tooling pre-configured. Start coding your features immediately.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"></div>
                <h3>Production Ready</h3>
                <p>First-class support for Docker and Nix. Consistent environments from dev to production.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"></div>
                <h3>Lightweight & Focused</h3>
                <p>Open-source, lightweight, and focused. Built by a developer for developers who value simplicity.</p>
            </div>
        </div>

        <section class="install-section">
            <h2>Ready to speed up?</h2>
            <p class="tagline">Install the binary globally and start building.</p>

            <div class="code-box">
                <code id="install-code">go install github.com/rafaeldepontes/gini@latest</code>
                <button class="copy-btn">Copy</button>
            </div>

            <div class="cta-group">
                <a href="https://github.com/rafaeldepontes/gini" class="btn btn-primary" target="_blank" rel="noopener">View on GitHub</a>
                <a href="https://github.com/rafaeldepontes/gini/blob/main/LICENSE" class="btn btn-ghost" target="_blank" rel="noopener">MIT License</a>
            </div>
        </section>

        <footer>
            <p>
                Gini — Go Init · Handcrafted by <a href="https://github.com/rafaeldepontes" target="_blank" rel="noopener">Rafael</a><br>
                <small style="margin-top: 8px; display: block;">&copy; 2026 Gini Project. All rights reserved.</small>
            </p>
        </footer>
    </div>

    <!-- Scripts -->
    <script src="public/js/main.js"></script>
</body>

</html>
